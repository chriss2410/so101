# SO-101 environment
# Copy to `.env` and edit for your setup. Every command reads this file so you
# never have to retype port paths or arm ids.

# --- Serial ports (find with: `so101 find-port`) ----------------------------
# macOS:   /dev/tty.usbmodem58760431541
# Linux:   /dev/ttyACM0
# Windows: COM3
FOLLOWER_PORT=/dev/tty.usbmodem58760431541
LEADER_PORT=/dev/tty.usbmodem58760431551

# --- Arm ids (used to store calibration files under ~/.cache/lerobot/) ------
FOLLOWER_ID=so101_follower_a
LEADER_ID=so101_leader_a

# --- Camera ----------------------------------------------------------------
# Two backends supported:
#   CAMERA_TYPE=opencv        - any USB webcam (built-in or external)
#   CAMERA_TYPE=intelrealsense - Intel RealSense (D405 / D415 / D435 / etc.)
#
# For RealSense: find your serial number with `so101 find-cameras realsense`,
# then paste it as CAM_SERIAL. Depth stream is off by default; set
# CAM_USE_DEPTH=true to enable it.
#
# For OpenCV: index 0 is usually the built-in camera; use 1+ for a USB webcam.
# Set CAMERA_TYPE=none to record a state-only dataset (no video).
CAMERA_TYPE=opencv
CAM_INDEX=0
CAM_SERIAL=
CAM_USE_DEPTH=false
CAM_WIDTH=640
CAM_HEIGHT=480
CAM_FPS=30

# --- Recording -------------------------------------------------------------
# HuggingFace user + dataset name. Full repo id will be <HF_USER>/<DATASET_NAME>.
HF_USER=your-hf-username
DATASET_NAME=so101-pick-cube
# HuggingFace write token (https://huggingface.co/settings/tokens).
# Required for `--upload` and `--auto-name`. Never commit this to git.
HF_TOKEN=
TASK_DESCRIPTION="Pick up the red cube and place it in the box"
NUM_EPISODES=20
EPISODE_TIME_SEC=30
RESET_TIME_SEC=10

# --- Inference -------------------------------------------------------------
# HuggingFace repo id of a trained policy checkpoint, OR a local directory
# path pointing at a `pretrained_model/` folder produced by `so101 train`.
POLICY_PATH=your-hf-username/so101-pick-cube-act

# --- Runtime ---------------------------------------------------------------
# cuda | mps | cpu
# - cuda: NVIDIA GPU (Linux/Windows)
# - mps:  Apple Silicon
# - cpu:  everything else (including AMD GPUs on Windows - see README).
#         ACT at 6 DoF / 30 Hz control is comfortably real-time on CPU.
DEVICE=cpu

# --- Weights & Biases ------------------------------------------------------
# Leave WANDB_API_KEY empty to disable wandb logging (default).
# Get a key at https://wandb.ai/authorize. Never commit this file.
WANDB_API_KEY=
WANDB_PROJECT=so101
WANDB_ENTITY=

# --- Remote inference (so101 infer-remote) ---------------------------------
# LeRobot's async inference splits the policy server from the robot client.
# The GPU server runs `python -m lerobot.async_inference.policy_server`;
# the Mac runs `python -m lerobot.async_inference.robot_client`.
#
# SERVER_SSH_HOST     - SSH alias/host for the GPU box (managed by ecm).
# SERVER_ADDRESS      - host:port the client dials. Public IP or DNS of the
#                        GPU box. Port must be open in the box's security
#                        group. 7860 is open to SAP VPN in the fleet's
#                        `sap-vpn-http` SG so it doubles as our gRPC port.
# SERVER_POLICY_DEVICE- device the SERVER uses to run the policy (cuda|cpu).
# CLIENT_DEVICE       - device the CLIENT uses for action aggregation
#                        (cpu is fine, mps not needed).
# ACTIONS_PER_CHUNK   - how many actions the server sends per chunk. Higher
#                        = more resilience to network jitter, less
#                        responsive to sudden state changes. ACT was trained
#                        with chunk_size=100 by default; 20 is plenty here.
# CHUNK_SIZE_THRESHOLD- when the client's remaining action queue drops
#                        below this fraction of the chunk, request the next
#                        one. 0.5 = request next chunk when half-empty.
# AGGREGATE_FN        - how to blend the last action of the previous chunk
#                        with the first of the new one:
#                        weighted_average | latest_only | average |
#                        conservative
SERVER_SSH_HOST=research-1xA10
SERVER_ADDRESS=
SERVER_POLICY_DEVICE=cuda
CLIENT_DEVICE=cpu
ACTIONS_PER_CHUNK=20
CHUNK_SIZE_THRESHOLD=0.5
AGGREGATE_FN=weighted_average
